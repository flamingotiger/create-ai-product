{
  "name": "create-ai-product",
  "version": "0.1.0",
  "description": "Create a minimal Next.js AI starter project.",
  "type": "module",
  "bin": {
    "create-ai-product": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.39.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0",
    "typescript": "^5.7.2"
  }
}
